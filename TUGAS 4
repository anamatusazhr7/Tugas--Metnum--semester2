        "import numpy as np\n",
        "from numpy.linalg import inv\n",
        "\n",
        "# Matriks Augmented [A|b]\n",
        "A = np.array([[3, 2, 1],\n",
        "              [1, 4, 2],\n",
        "              [2, 1, 5]], dtype=float)\n",
        "b = np.array([9, 13, 17], dtype=float)\n",
        "augmented = np.column_stack((A, b))\n",
        "\n",
        "print(\"=== MATRIKS AUGMENTED ===\")\n",
        "print(augmented)\n",
        "print()\n",
        "\n",
        "# 1. ELIMINASI GAUSS\n",
        "def gauss_elimination(A, b):\n",
        "    n = len(b)\n",
        "    # Buat matriks augmented\n",
        "    Ab = np.column_stack((A.copy(), b.copy()))\n",
        "\n",
        "    # Forward elimination\n",
        "    for i in range(n):\n",
        "        # Pivot\n",
        "        pivot = Ab[i, i]\n",
        "        Ab[i] = Ab[i] / pivot\n",
        "\n",
        "        # Eliminasi\n",
        "        for k in range(i+1, n):\n",
        "            factor = Ab[k, i]\n",
        "            Ab[k] = Ab[k] - factor * Ab[i]\n",
        "\n",
        "    # Back substitution\n",
        "    x = np.zeros(n)\n",
        "    for i in range(n-1, -1, -1):\n",
        "        x[i] = Ab[i, -1]\n",
        "        for j in range(i+1, n):\n",
        "            x[i] -= Ab[i, j] * x[j]\n",
        "\n",
        "    return x\n",
        "\n",
        "print(\"1. ELIMINASI GAUSS\")\n",
        "x_gauss = gauss_elimination(A, b)\n",
        "print(\"Solusi:\", x_gauss)\n",
        "print()\n",
        "\n",
        "# 2. ELIMINASI GAUSS-JORDAN\n",
        "def gauss_jordan(A, b):\n",
        "    n = len(b)\n",
        "    Ab = np.column_stack((A.copy(), b.copy()))\n",
        "\n",
        "    # Forward elimination\n",
        "    for i in range(n):\n",
        "        pivot = Ab[i, i]\n",
        "        Ab[i] = Ab[i] / pivot\n",
        "        for k in range(i+1, n):\n",
        "            factor = Ab[k, i]\n",
        "            Ab[k] = Ab[k] - factor * Ab[i]\n",
        "\n",
        "    # Backward elimination\n",
        "    for i in range(n-1, -1, -1):\n",
        "        for k in range(i-1, -1, -1):\n",
        "            factor = Ab[k, i]\n",
        "            Ab[k] = Ab[k] - factor * Ab[i]\n",
        "\n",
        "    return Ab[:, -1]\n",
        "\n",
        "print(\"2. ELIMINASI GAUSS-JORDAN\")\n",
        "x_gj = gauss_jordan(A, b)\n",
        "print(\"Solusi:\", x_gj)\n",
        "print()\n",
        "\n",
        "# 3. MATRIKS INVERS\n",
        "print(\"3. MATRIKS INVERS\")\n",
        "A_inv = inv(A)\n",
        "x_inv = A_inv @ b\n",
        "print(\"A⁻¹ =\", np.round(A_inv, 4))\n",
        "print(\"Solusi:\", x_inv)\n",
        "print()\n",
        "\n",
        "# 4. ITERASI JACOBI\n",
        "def jacobi_iteration(A, b, x0, tol=1e-6, max_iter=100):\n",
        "    n = len(b)\n",
        "    D = np.diag(np.diag(A))\n",
        "    R = A - D\n",
        "    x = x0.copy()\n",
        "\n",
        "    for k in range(max_iter):\n",
        "        x_new = np.linalg.inv(D) @ (b - R @ x)\n",
        "        if np.linalg.norm(x_new - x) < tol:\n",
        "            return x_new, k+1\n",
        "        x = x_new\n",
        "    return x, max_iter\n",
        "\n",
        "print(\"4. ITERASI JACOBI\")\n",
        "x0 = np.zeros(3)\n",
        "x_jacobi, iter_j = jacobi_iteration(A, b, x0)\n",
        "print(\"Solusi:\", x_jacobi)\n",
        "print(\"Iterasi:\", iter_j)\n",
        "print()\n",
        "\n",
        "# 5. ITERASI GAUSS-SEIDEL\n",
        "def gauss_seidel_iteration(A, b, x0, tol=1e-6, max_iter=100):\n",
        "    n = len(b)\n",
        "    L = np.tril(A, -1)\n",
        "    D = np.diag(np.diag(A))\n",
        "    U = np.triu(A, 1)\n",
        "    x = x0.copy()\n",
        "    for k in range(max_iter):\n",
        "        x_new = np.linalg.inv(D + L) @ (b - U @ x)\n",
        "        if np.linalg.norm(x_new - x) < tol:\n",
        "            return x_new, k+1\n",
        "        x = x_new\n",
        "    return x, max_iter\n",
        "print(\"5. ITERASI GAUSS-SEIDEL\")\n",
        "x_gs, iter_gs = gauss_seidel_iteration(A, b, x0)\n",
        "print(\"Solusi:\", x_gs)\n",
        "print(\"Iterasi:\", iter_gs)\n",
        "print()\n",
        "# VERIFIKASI\n",
        "print(\"=== VERIFIKASI SEMUA METODE ===\")\n",
        "methods = {\n",
        "    'Gauss': x_gauss,\n",
        "    'Gauss-Jordan': x_gj,\n",
        "    'Invers': x_inv,\n",
        "    'Jacobi': x_jacobi,\n",
        "    'Gauss-Seidel': x_gs\n",
        "}\n",
        "for name, sol in methods.items():\n",
        "    residual = np.linalg.norm(A @ sol - b)\n",
        "    print(f\"{name:12}: Error = {residual:.2e}\")"
      ]
    }
